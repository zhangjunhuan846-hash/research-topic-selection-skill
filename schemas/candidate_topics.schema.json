{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CandidateTopics",
  "type": "object",
  "required": ["candidates"],
  "properties": {
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_id", "title", "science_question", "hypothesis"],
        "properties": {
          "candidate_id": {"type": "string"},
          "title": {"type": "string"},
          "science_question": {"type": "string"},
          "hypothesis": {"type": "string"},
          "ai_role": {"type": "string"}
        }
      }
    }
  }
}
